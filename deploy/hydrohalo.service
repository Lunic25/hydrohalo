[Unit]
Description=HydroHalo Kiosk
After=local-fs.target
Wants=local-fs.target

[Service]
Type=simple
User=lunic21
WorkingDirectory=/home/lunic21/hydrohalo
Environment=HOME=/home/lunic21
ExecStart=/usr/bin/startx /home/lunic21/hydrohalo/deploy/xinitrc -- -nocursor
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target